package rules;

import com.ftn.sbnz.model.ShotAttempt;
import com.ftn.sbnz.model.ZoneProfile;
import com.ftn.sbnz.model.facts.ShotEvaluation;

rule "L2 - idealna catch and shoot"
    agenda-group "level2"
    lock-on-active
    when
        $shot    : ShotAttempt( dribbles <= 1, touchTimeSec <= 2.0,
                                defenderDistFt > 4.0,
                                $sid : shotId, $zone : zone )
        $profile : ZoneProfile( zone == $zone, highValue == true )
        $eval    : ShotEvaluation( shotId == $sid, quality == null ) @watch( !score, !activeFactors )
    then
        System.out.println("  [L2] idealna catch-and-shoot +10");
        modify($eval) {
            setScore($eval.getScore() + 10),
            addFactor("Idealna catch-and-shoot +10")
        }
end
